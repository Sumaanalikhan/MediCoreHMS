@model IEnumerable<MediCoreHMS.Models.Patient>
@{
    ViewData["Title"] = "Patients";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="fw-bold">Patients</h4>
    <a asp-action="Create" class="btn btn-primary">Add Patient</a>
</div>

<div class="card shadow rounded-4">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Name</th>
                    <th>Age</th>
                    <th>Gender</th>
                    <th>Phone</th>
                    <th>Arrival</th>
                    <th>Registered</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td>@p.FullName</td>
                        <td>@p.Age</td>
                        <td>@p.Gender</td>
                        <td>@p.PhoneNumber</td>
                        <td>@p.ArrivalType</td>
                        <td>@p.RegistrationDate.ToString("dd/MM/yyyy")</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@p.PatientId" class="btn btn-sm btn-outline-primary">View</a>
                            <a asp-action="Edit" asp-route-id="@p.PatientId" class="btn btn-sm btn-outline-warning">Edit</a>
                            <a asp-action="Delete" asp-route-id="@p.PatientId" class="btn btn-sm btn-outline-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>