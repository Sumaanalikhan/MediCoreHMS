@model MediCoreHMS.Models.Bed
@{
    ViewData["Title"] = "Edit Bed";
}

<h4 class="fw-bold mb-3">✏️ Edit Bed</h4>
<div class="card shadow rounded-4 p-4" style="max-width:400px">
    <form method="post" action="/Beds/Edit/@Model.BedId">
        @Html.AntiForgeryToken()
        <input type="hidden" name="BedId" value="@Model.BedId" />
        <div class="mb-3">
            <label asp-for="BedNumber" class="form-label"></label>
            <input asp-for="BedNumber" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="Ward" class="form-label"></label>
            <select asp-for="Ward" class="form-select">
                <option>General</option>
                <option>ICU</option>
                <option>Maternity</option>
                <option>Pediatric</option>
            </select>
        </div>
        <div class="mb-3 form-check">
            <input asp-for="IsOccupied" class="form-check-input" type="checkbox" />
            <label asp-for="IsOccupied" class="form-check-label">Occupied</label>
        </div>
        <button type="submit" class="btn btn-warning">Update</button>
        <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
    </form>
</div>