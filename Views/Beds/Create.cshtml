@model MediCoreHMS.Models.Bed
@{
    ViewData["Title"] = "Add Bed";
}

<h4 class="fw-bold mb-3">Add Bed</h4>
<div class="card shadow rounded-4 p-4" style="max-width:400px">
    <form method="post" action="/Beds/Create">
        @Html.AntiForgeryToken()
        <div class="mb-3">
            <label class="form-label">Bed Number</label>
            <input name="BedNumber" class="form-control" required />
        </div>
        <div class="mb-3">
            <label class="form-label">Ward</label>
            <select name="Ward" class="form-select">
                <option>General</option>
                <option>ICU</option>
                <option>Maternity</option>
                <option>Pediatric</option>
            </select>
        </div>
        <button type="submit" class="btn btn-primary">Save Bed</button>
        <a href="/Beds" class="btn btn-secondary ms-2">Cancel</a>
    </form>
</div>