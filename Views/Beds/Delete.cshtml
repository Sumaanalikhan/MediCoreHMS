@model MediCoreHMS.Models.Doctor
@{
    ViewData["Title"] = "Delete Doctor";
}

<h4 class="fw-bold mb-3 text-danger">Delete Doctor</h4>
<div class="card shadow rounded-4 p-4" style="max-width:500px">
    <p>Delete <strong>@Model.FullName</strong>?</p>
    <form method="post" action="/Doctors/Delete/@Model.DoctorId">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-danger">Yes, Delete</button>
        <a href="/Doctors" class="btn btn-secondary ms-2">Cancel</a>
    </form>
</div>