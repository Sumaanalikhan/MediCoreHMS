@model IEnumerable<MediCoreHMS.Models.Doctor>
@{
    ViewData["Title"] = "Doctors";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="fw-bold">👨‍⚕️ Doctors</h4>
    <a asp-action="Create" class="btn btn-primary"><i class="fas fa-plus me-1"></i>Add Doctor</a>
</div>

<div class="card shadow rounded-4">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr><th>Name</th><th>Specialization</th><th>Ward</th><th>Schedule</th><th>Status</th><th>Actions</th></tr>
            </thead>
            <tbody>
                @foreach (var d in Model)
                {
                    <tr>
                        <td>@d.FullName</td>
                        <td>@d.Specialization</td>
                        <td>@d.AssignedWard</td>
                        <td>@d.ConsultationSchedule</td>
                        <td><span class="badge @(d.IsAvailable ? "bg-success" : "bg-secondary")">@(d.IsAvailable ? "Available" : "Unavailable")</span></td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@d.DoctorId" class="btn btn-sm btn-outline-warning">Edit</a>
                            <a asp-action="Delete" asp-route-id="@d.DoctorId" class="btn btn-sm btn-outline-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>