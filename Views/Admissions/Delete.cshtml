@model MediCoreHMS.Models.Admission
@{
    ViewData["Title"] = "Delete Admission";
}

<h4 class="fw-bold mb-3 text-danger">Delete Admission</h4>
<div class="card shadow rounded-4 p-4" style="max-width:500px">
    <p>Delete admission for <strong>@Model.Patient?.FullName</strong>?</p>
    <form method="post" action="/Admissions/Delete/@Model.AdmissionId">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-danger">Yes, Delete</button>
        <a href="/Admissions" class="btn btn-secondary ms-2">Cancel</a>
    </form>
</div>