@model IEnumerable<MediCoreHMS.Models.Admission>
@{
    ViewData["Title"] = "Admissions";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="fw-bold">📋 Admissions</h4>
    <a asp-action="Create" class="btn btn-primary"><i class="fas fa-plus me-1"></i>New Admission</a>
</div>

<div class="card shadow rounded-4">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr><th>Patient</th><th>Doctor</th><th>Ward</th><th>Bed</th><th>Admitted</th><th>Type</th><th>Status</th><th>Actions</th></tr>
            </thead>
            <tbody>
                @foreach (var a in Model)
                {
                    <tr>
                        <td>@a.Patient?.FullName</td>
                        <td>@a.Doctor?.FullName</td>
                        <td>@a.Ward</td>
                        <td>@a.Bed?.BedNumber</td>
                        <td>@a.AdmissionDate.ToString("dd/MM/yyyy")</td>
                        <td><span class="badge @(a.AdmissionType == "Emergency" ? "bg-danger" : "bg-info")">@a.AdmissionType</span></td>
                        <td><span class="badge @(a.Status == "Admitted" ? "bg-primary" : "bg-success")">@a.Status</span></td>
                        <td>
                            <a asp-action="Details" asp-route-id="@a.AdmissionId" class="btn btn-sm btn-outline-primary">View</a>
                            @if (a.Status == "Admitted")
                            {
                                <a asp-action="Discharge" asp-route-id="@a.AdmissionId" class="btn btn-sm btn-outline-success">Discharge</a>
                            }
                            <a asp-action="Delete" asp-route-id="@a.AdmissionId" class="btn btn-sm btn-outline-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>